{
  "manifest_version": 3,
  "name": "sitecap",
  "version": "0.1.0",
  "description": "Bridge between sitecap CLI and your authenticated Chrome session",
  "permissions": [
    "debugger",
    "tabs",
    "cookies",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "Click to connect sitecap CLI"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
