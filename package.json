{
  "name": "sitecap",
  "version": "0.1.0",
  "description": "Exhaustive web page capture — screenshot, accessibility tree, HTML source, network requests, console logs, storage state.",
  "type": "module",
  "main": "./index.js",
  "exports": {
    ".": "./index.js",
    "./capture": "./lib/capture.js",
    "./diff": "./lib/diff.js"
  },
  "bin": {
    "sitecap": "./bin/sitecap.js"
  },
  "scripts": {
    "start": "node bin/sitecap.js",
    "mcp": "node bin/mcp-server.js",
    "api": "node bin/api-server.js",
    "test": "vitest run"
  },
  "keywords": [
    "capture",
    "archive",
    "screenshot",
    "accessibility",
    "web"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "js-yaml": "^4.1.1",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "vitest": "^4.1.0"
  }
}
